.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 30rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 60rpx 0;
}

.icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.feature-icon {
  color: #2E8B57;
  font-size: 32rpx;
}

.feature-text {
  font-size: 30rpx;
  color: #333;
}

.warning-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  padding: 20rpx;
  background: #fff7e6;
  border-radius: 12rpx;
}

.warning-icon {
  font-size: 48rpx;
}

.warning-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
}

.btn-container {
  padding: 20rpx 0;
}

.btn-primary {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #2E8B57;
  color: #fff;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-primary:active {
  background: #257347;
}

.tips {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #999;
}